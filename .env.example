# ─────────────────────────────────────────────────────────────────────────────
# Copy this file, rename it to ".env", and fill in your real values.
# NEVER share your .env file with anyone — it contains your secret keys.
# ─────────────────────────────────────────────────────────────────────────────

# Your Anthropic API key — get it from https://console.anthropic.com/
ANTHROPIC_API_KEY=paste_your_anthropic_api_key_here

# Your Gmail App Password — see Step 2 in setup.py for instructions
GMAIL_APP_PASSWORD=paste_your_gmail_app_password_here
